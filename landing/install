#!/bin/sh
set -e

# cray installer
# Usage: curl -fsSL https://cray.my/install | sh

REPO="accnops/cray"
INSTALL_DIR="/usr/local/bin"
INSTALL_LIB="/usr/local/lib/cray"

# Detect OS
OS="$(uname -s)"
case "$OS" in
  Darwin) OS="darwin" ;;
  Linux) OS="linux" ;;
  *) echo "Unsupported OS: $OS"; exit 1 ;;
esac

# Detect architecture
ARCH="$(uname -m)"
case "$ARCH" in
  x86_64) ARCH="x64" ;;
  amd64) ARCH="x64" ;;
  arm64) ARCH="arm64" ;;
  aarch64) ARCH="arm64" ;;
  *) echo "Unsupported architecture: $ARCH"; exit 1 ;;
esac

PLATFORM="${OS}-${ARCH}"

echo "Installing cray for ${PLATFORM}..."

# Get latest release tarball URL from GitHub
DOWNLOAD_URL="https://github.com/${REPO}/releases/latest/download/cray-${PLATFORM}.tar.gz"

# Create temp directory
TMP_DIR="$(mktemp -d)"
trap "rm -rf ${TMP_DIR}" EXIT

# Download and extract
echo "Downloading from ${DOWNLOAD_URL}..."
if command -v curl > /dev/null; then
  curl -fsSL "$DOWNLOAD_URL" | tar -xz -C "${TMP_DIR}"
elif command -v wget > /dev/null; then
  wget -qO- "$DOWNLOAD_URL" | tar -xz -C "${TMP_DIR}"
else
  echo "Error: curl or wget required"
  exit 1
fi

# Install binary and web assets
if [ -w "$INSTALL_DIR" ] && [ -w "$(dirname $INSTALL_LIB)" ]; then
  rm -rf "${INSTALL_LIB}"
  mkdir -p "${INSTALL_LIB}"
  cp -r "${TMP_DIR}/cray-${PLATFORM}/web" "${INSTALL_LIB}/"
  cp "${TMP_DIR}/cray-${PLATFORM}/cray" "${INSTALL_DIR}/cray"
  chmod +x "${INSTALL_DIR}/cray"
else
  echo "Installing to ${INSTALL_DIR} (requires sudo)..."
  sudo rm -rf "${INSTALL_LIB}"
  sudo mkdir -p "${INSTALL_LIB}"
  sudo cp -r "${TMP_DIR}/cray-${PLATFORM}/web" "${INSTALL_LIB}/"
  sudo cp "${TMP_DIR}/cray-${PLATFORM}/cray" "${INSTALL_DIR}/cray"
  sudo chmod +x "${INSTALL_DIR}/cray"
fi

echo ""
echo "cray installed successfully!"
echo "Run 'cray' to get started."
